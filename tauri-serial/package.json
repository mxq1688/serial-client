{
  "name": "tauri-serial",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron-main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron-dev": "vite & electron .",
    "dist": "vite build && electron-builder",
    "dist:win": "vite build && electron-builder --win --x64",
    "tauri": "tauri"
  },
  "build": {
    "appId": "com.logcat.debugger",
    "productName": "Logcat Serial Debugger",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@tauri-apps/api": "^1.5.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.6.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "serialport": "^13.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.4.0"
  }
}
